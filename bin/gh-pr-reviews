#!/bin/sh -e
#
# git-pr-reviews
#
# I review a lot of code. Like so much code. So much code my wife asks my why I
# don't read books and it's because I'm busy reading pull requests.
#
# It's all good though. It's honest work and I need some tools to unlock quick
# workflows.

# Prefer the repo slug over remote URL matching so SSH and HTTPS remotes both work.
CURRENT_REPO="$(gh repo view --json nameWithOwner --jq .nameWithOwner)"

# Last-two-weeks date: prefer macOS `date -v`, fall back to GNU `date -d`
SINCE="$(date -v-14d +%Y-%m-%d 2>/dev/null || date -d '14 days ago' +%Y-%m-%d)"

# Bump with `LIMIT=200 gh-pr-reviews` if your last-two-weeks docket is huge.
LIMIT="${LIMIT:-100}"

# Need this to identify "my" reviews in the post-filter step below.
# Exported so xargs-spawned subshells inherit it.
MY_LOGIN="$(gh api user --jq .login)"
export MY_LOGIN

search_prs() {
  query="$1"

  gh search prs "$query" \
    --repo "$CURRENT_REPO" \
    --state open \
    --draft=false \
    --created ">$SINCE" \
    --sort created --order desc \
    --limit "$LIMIT" \
    --json title,number,url,createdAt
}

# `review-requested:@me` returns PRs where you or one of your teams is requested.
# `user-review-requested:@me` returns only PRs where you are directly requested.
ALL_PRS="$(search_prs 'review-requested:@me')"
DIRECT_URLS="$(search_prs 'user-review-requested:@me' | jq -c '[.[].url]')"

# Annotate each PR with the bucket it belongs in. If a PR has both a direct and
# a team review request, keep it in the higher-priority direct bucket.
PRS="$(echo "$ALL_PRS" | jq --argjson direct_urls "$DIRECT_URLS" '
  def is_direct($url): any($direct_urls[]?; . == $url);
  [.[] | . + {
    reviewRequestGroup: (if is_direct(.url) then "direct" else "team" end)
  }]
')"

# Drop PRs where my latest review is APPROVED. `latestReviews` returns at most
# one entry per reviewer (their most recent), so we just look up mine. PRs
# where I commented, requested changes, or had an approval dismissed by new
# commits will still show -- only a clean APPROVED state hides the PR.
#
# Parallelized with `xargs -P 8`: the per-PR `gh pr view` calls fire in batches
# of 8 instead of one-at-a-time. Output order is non-deterministic after this;
# each display bucket re-sorts by createdAt below.
PRS="$(printf '%s\n' "$PRS" | jq -c '.[]' \
  | tr '\n' '\0' \
  | xargs -0 -n 1 -P 8 sh -c '
      pr="$1"
      [ -z "$pr" ] && exit 0

      url=$(printf "%s" "$pr" | jq -r ".url")
      state=$(gh pr view "$url" --json latestReviews \
        --jq ".latestReviews[]? | select(.author.login == \"$MY_LOGIN\") | .state" \
        2>/dev/null || echo "")

      [ "$state" = "APPROVED" ] || printf "%s\n" "$pr"
    ' _ \
  | jq -s '.')"

COUNT="$(echo "$PRS" | jq 'length // 0')"
if [ "${COUNT:-0}" -eq 0 ]; then
  echo "No open PRs awaiting your review for this repo."
  exit 0
fi

DIRECT_COUNT="$(echo "$PRS" | jq '[.[] | select(.reviewRequestGroup == "direct")] | length')"
TEAM_COUNT="$(echo "$PRS" | jq '[.[] | select(.reviewRequestGroup == "team")] | length')"

echo "$PRS" | jq -r --argjson direct_count "$DIRECT_COUNT" --argjson team_count "$TEAM_COUNT" '
  def reltime($t):
    (now - ($t | fromdateiso8601)) as $d
    | if   $d < 60      then (($d|floor)|tostring) + (if ($d|floor) == 1 then " second ago" else " seconds ago" end)
      elif $d < 3600    then ((($d/60)|floor)|tostring) + (if (($d/60)|floor) == 1 then " minute ago" else " minutes ago" end)
      elif $d < 86400   then ((($d/3600)|floor)|tostring) + (if (($d/3600)|floor) == 1 then " hour ago" else " hours ago" end)
      else
        (($d/86400)|floor) as $days
        | (($d - ($days * 86400)) / 3600 | floor) as $hours
        | ($days|tostring)
          + (if $days == 1 then " day" else " days" end)
          + (if $hours > 0 then " " + ($hours|tostring) + (if $hours == 1 then " hour" else " hours" end) else "" end)
          + " ago"
      end;
  def md_escape_pipes($s):
    ($s | split("|") | join("\\|"));
  def line:
    .createdAt as $c
    | "[\(.number)] \(md_escape_pipes(.title)) (\(reltime($c))) \(.url)";
  def section($title; $items):
    if ($items | length) == 0 then
      empty
    else
      $title,
      ($items | sort_by(.createdAt) | reverse | .[] | line),
      ""
    end;

  . as $prs
  | section("Explicitly requested (@me) (\($direct_count))\n----------------------------"; [$prs[] | select(.reviewRequestGroup == "direct")]),
    section("Team / required-reviewer requests (\($team_count))\n---------------------------------"; [$prs[] | select(.reviewRequestGroup == "team")])
' | sed '${/^$/d;}'
